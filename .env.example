# ─────────────────────────────────────────────────────────
#  inference.py — Local environment variables
#  Copy this to .env and fill in your values.
#  NEVER commit .env to git (it's in .gitignore already).
# ─────────────────────────────────────────────────────────

# Docker image tag for the environment server
IMAGE_NAME=corporate-expense-openenv:latest

# Your Hugging Face User Access Token (https://huggingface.co/settings/tokens)
# Used to call LLMs via the HF Inference Router
HF_TOKEN=hf_your_token_here

# LLM API endpoint (OpenAI-compatible)
# Default: HF Inference Router (free tier available)
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for expense decisions
# Free options via HF Router:
#   Qwen/Qwen2.5-72B-Instruct         (recommended)
#   meta-llama/Llama-3.3-70B-Instruct
#   mistralai/Mixtral-8x7B-Instruct-v0.1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Task difficulty: easy | medium | hard  (default: easy)
CORPORATE_EXPENSE_TASK=easy
